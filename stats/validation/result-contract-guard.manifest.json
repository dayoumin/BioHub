    "stats/types/smart-flow.ts",
    "stats/types/analysis.ts",
    "stats/scripts/statistics/validate-result-contracts.ts",
    "stats/validation/scripts/run-validation.mjs",
    "stats/validation/scripts/result-contract-guard.mjs",
    "stats/validation/result-contract-guard.manifest.json",
    "stats/__tests__/lib/validation/result-schema-validator.test.ts",
    "stats/__tests__/services/executors/statistical-executor-routing.test.ts",
    "stats/__tests__/lib/services/slot-to-executor-pipeline.test.ts",
    "stats/__tests__/lib/services/slot-to-executor-runtime-regressions.test.ts",
    "stats/__tests__/lib/registry/method-registry-regressions.test.ts",
    "stats/__tests__/components/analysis/steps/MethodBrowserStep.scenario.test.tsx",
    "stats/__tests__/components/analysis/steps/VariableSelectionStep.test.tsx",
    "stats/__tests__/components/analysis/steps/AnalysisExecutionStep.test.tsx",
    "stats/__tests__/hooks/use-analysis-handlers.test.ts",
    "stats/__tests__/hooks/use-data-upload-scenarios.test.ts",
    "stats/__tests__/hooks/use-data-upload-quick-advance.test.ts",
    "stats/__tests__/hooks/use-hub-data-upload.test.ts",
    "stats/__tests__/services/handlers/handle-design.test.ts",
    "stats/__tests__/statistics/chi-square-validation.test.ts",
    "stats/__tests__/contracts/method-id-unification.contract.test.ts",
    "stats/__tests__/integration/method-id-unification-simulation.test.ts",
    "stats/__tests__/lib/services/result-interpreter.test.ts",
    "stats/__tests__/lib/services/export/code-export.test.ts",
    "stats/__tests__/unit/result-transformer.test.ts",
    "stats/__tests__/validation/result-contract-guard-manifest.test.ts",
    "stats/lib/research/__tests__/report-apa-format.test.ts",
    "stats/lib/utils/__tests__/method-identity.test.ts"
  ],
  "commands": [
    {
      "name": "Validate result contracts",
      "workingDirectory": "stats",
      "run": "pnpm run validate:result-contracts"
    },
    {
      "name": "Run validator tests",
      "workingDirectory": "stats",
      "run": "pnpm test --run __tests__/lib/validation/result-schema-validator.test.ts __tests__/validation/result-contract-guard-manifest.test.ts"
    },
    {
      "name": "Run executor routing tests",
      "workingDirectory": "stats",
      "run": "pnpm test --run __tests__/services/executors/statistical-executor-routing.test.ts"
    },
    {
      "name": "Run selector and flow regression tests",
      "workingDirectory": "stats",
      "run": "pnpm test --run __tests__/components/analysis/steps/MethodBrowserStep.scenario.test.tsx __tests__/components/analysis/steps/VariableSelectionStep.test.tsx __tests__/components/analysis/steps/AnalysisExecutionStep.test.tsx __tests__/lib/services/slot-to-executor-pipeline.test.ts __tests__/lib/services/slot-to-executor-runtime-regressions.test.ts __tests__/lib/registry/method-registry-regressions.test.ts __tests__/hooks/use-analysis-handlers.test.ts __tests__/hooks/use-data-upload-scenarios.test.ts __tests__/hooks/use-data-upload-quick-advance.test.ts __tests__/hooks/use-hub-data-upload.test.ts __tests__/services/handlers/handle-design.test.ts __tests__/statistics/chi-square-validation.test.ts"
    },
    {
      "name": "Run method-id unification tests",
      "workingDirectory": "stats",
      "run": "pnpm test --run __tests__/contracts/method-id-unification.contract.test.ts __tests__/integration/method-id-unification-simulation.test.ts lib/utils/__tests__/method-identity.test.ts"
    },
    {
      "name": "Run interpretation, export, and APA tests",
      "workingDirectory": "stats",
      "run": "pnpm test --run __tests__/lib/services/result-interpreter.test.ts __tests__/lib/services/export/code-export.test.ts lib/research/__tests__/report-apa-format.test.ts"
    },
    {
      "name": "Run validation smoke",
      "workingDirectory": "stats",
      "run": "pnpm test:validation --layer L2 --report"
    },
    {
      "name": "Run transformer tests",
      "workingDirectory": "stats",
      "run": "pnpm test --run __tests__/unit/result-transformer.test.ts"
    }
  ]
}
