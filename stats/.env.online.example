# 온라인 배포용 환경 변수 (Cloudflare Workers)
#
# 사용법:
# 1. 빌드 시 환경 변수: GitHub Actions secrets에 등록
# 2. Worker secrets: npx wrangler secret put OPENROUTER_API_KEY (1회)
# 3. 로컬 테스트용: cp .env.online.example .env.local 후 값 채우기

# =====================================================
# Turso DB (히스토리 저장 - 빌드 시 번들 포함)
# =====================================================
NEXT_PUBLIC_TURSO_URL=libsql://your-db-name.turso.io
NEXT_PUBLIC_TURSO_AUTH_TOKEN=your_turso_auth_token_here

# =====================================================
# OpenRouter (AI 추천)
# =====================================================
# API 키는 Worker secrets로 관리 (번들 미포함):
#   npx wrangler secret put OPENROUTER_API_KEY
# 모델 목록만 빌드 시 포함 (비밀 아님):
NEXT_PUBLIC_OPENROUTER_MODEL=x-ai/grok-4.1-fast,openai/gpt-oss-120b:free

# =====================================================
# Pyodide (통계 계산 - CDN 사용, 변경 불필요)
# =====================================================
# NEXT_PUBLIC_PYODIDE_USE_LOCAL=false  ← 기본값이 false이므로 생략 가능
